# 自动处理文本文件，尝试纠正换行符
* text=auto

# 强制 Go 语言相关文件使用 LF 换行符（Linux/Docker 友好）
*.go text eol=lf
go.mod text eol=lf
go.sum text eol=lf

# 强制 Docker 相关文件使用 LF
Dockerfile* text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# 前端相关文件
*.vue text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf

# 图片、二进制文件保持原样
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.ico filter=lfs diff=lfs merge=lfs -text
