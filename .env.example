# =============================================================================
# 环境变量配置说明
# =============================================================================
# 本文件为 .env 的示例模板，复制为 .env 后按实际环境修改。
#
# 配置优先级（高 → 低）：
#   1. docker-compose.yml / docker-compose.dev.yml 中 environment 块的显式赋值
#      （如 DATABASE_HOST=postgres，固定为容器内服务名，不受 .env 影响）
#   2. .env 文件中的环境变量（通过 env_file 加载，可被上方 environment 块覆盖）
#   3. go-service/config.yaml 中的静态默认值（仅在对应环境变量未设置时生效）
#
# Viper 映射规则：环境变量中的 _ 自动映射为 config.yaml 中的 .
#   例：LOG_MAX_SIZE_MB  →  log.max_size_mb
#       DATABASE_DBNAME  →  database.dbname
# =============================================================================

# PostgreSQL（postgres 容器初始化参数，需与下方 DATABASE_* 保持一致）
POSTGRES_DB=oa_smart_audit
POSTGRES_USER=oa_admin
POSTGRES_PASSWORD=changeme_pg_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Go Service
JWT_SECRET=changeme_jwt_secret
ENCRYPTION_KEY=change-me-32-byte-key-in-prod!! # Must be exactly 32 bytes for AES-256
AI_SERVICE_URL=http://ai-service:8000

# 数据库连接（Go 服务读取；docker-compose.yml 中 environment 块会用 ${POSTGRES_*} 覆盖，
# 此处的值仅在直接运行 go-service 二进制（非 Docker）时生效）
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_DBNAME=oa_smart_audit
DATABASE_USER=oa_admin
DATABASE_PASSWORD=changeme_pg_password
DATABASE_SSLMODE=disable

MONGO_URI=mongodb://mongodb:27017

# -----------------------------------------------------------------------------
# 日志配置（对应 config.yaml log.* 字段，Viper 自动将环境变量中的 _ 映射为 .）
# 优先级：环境变量 > config.yaml 静态默认值
# -----------------------------------------------------------------------------

# LOG_LEVEL: 日志等级，可选 debug / info / warn / error，生产环境建议 info
LOG_LEVEL=info

# LOG_DIR: 日志文件根目录（容器内路径，已通过 volumes 挂载到宿主机）
LOG_DIR=/app/logs

# LOG_MAX_SIZE_MB: 单个日志文件最大体积（MB），超出后触发轮转
LOG_MAX_SIZE_MB=100

# LOG_MAX_BACKUPS: 轮转后最多保留的备份文件数量。
# 设为 0（默认）表示不限数量，完全由天数配置控制；设为正整数可额外限制数量上限。
# 注意：LOG_MAX_BACKUPS=0 且 LOG_GLOBAL_RETENTION_DAYS=0 时，
# lumberjack 不限数量，但每次清理任务（每日凌晨）会删除全部备份，两者并不冲突。
LOG_MAX_BACKUPS=0

# LOG_COMPRESS: 是否对备份文件进行 gzip 压缩（true/false）
LOG_COMPRESS=true

# LOG_GLOBAL_RETENTION_DAYS: 全局日志文件保留天数（兜底值）。
# 运行时优先读取数据库 system_configs 表中的配置（前端系统设置可修改）；
# 仅当数据库中无对应配置时，才回退到此环境变量的值。
# 注意：设为 0 时 cutoff = now，所有轮转备份文件均早于 now，每次清理任务都会删除全部备份。
# 当前正在写入的 app.log / tenant.log 不受影响，不会被删除。
LOG_GLOBAL_RETENTION_DAYS=30

# TZ: 容器时区，影响日志时间戳显示，默认 Asia/Shanghai（北京时间）
TZ=Asia/Shanghai

# Python AI Service
LLM_PROVIDER=local
LLM_MODEL_NAME=default
LLM_API_KEY=

# Nuxt Frontend
NUXT_PUBLIC_API_BASE=http://localhost:8080
NUXT_PUBLIC_MOCK_MODE=true
